rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net - deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Pattern 1: Data stored by user ID as the document ID (e.g., /users/{userId})
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow access to all subcollections under the user's document
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Pattern 2: (Template) Data stored in a generic collection but having an 'ownerId' or 'userId' field
    // match /someCollection/{docId} {
    //   // For reading/updating/deleting, check existing document's owner
    //   allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    //   // For creating, check the incoming document's owner matches the requester
    //   allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    // }
  }
}
